generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                    String        @id @default(cuid())
  email                 String        @unique
  passwordHash          String?
  name                  String?
  image                 String?
  loggedOutAt           DateTime?     // Safari 可能不清除 cookie，用此欄位在伺服器端使 session 失效
  subscription          String        @default("FREE")
  balance               Int           @default(0)
  points                Int           @default(0)
  stripeCustomerId      String?
  stripePaymentMethodId String?
  lastLoginDate         DateTime?
  consecutiveLoginDays  Int           @default(0)
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt
  goals                 Goal[]
  proofs                Proof[]
  coachProfile          CoachProfile?
  userItems             UserItem[]
}

model Goal {
  id                    String     @id @default(cuid())
  userId                String
  user                  User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  title                 String
  description           String
  dueAt                 DateTime
  penaltyCents          Int
  status                String     @default("ACTIVE")
  refundable            Boolean    @default(true)
  stripePaymentIntentId String?
  stripeChargeId        String?
  refundEligibleAt      DateTime?  // 非會員補完成後，可退款的日期（60 天後）
  createdAt             DateTime   @default(now())
  updatedAt             DateTime   @updatedAt
  proof                 Proof?
}

model Proof {
  id         String      @id @default(cuid())
  goalId     String      @unique
  goal       Goal        @relation(fields: [goalId], references: [id], onDelete: Cascade)
  userId     String
  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  type       String
  url        String
  status     String      @default("PENDING")
  reviewedAt DateTime?
  createdAt  DateTime    @default(now())
}

model CoachProfile {
  id                        String    @id @default(cuid())
  userId                    String    @unique
  user                      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  coachType                 String    @default("friend")
  coachGender               String    @default("male")
  affinity                  Int       @default(0)
  highestAffinityTierReached Int     @default(0)  // 曾達到的最高等級（0-9），用於商城可見
  equippedShopItemIds      String    @default("[]") // JSON array，最多 5 個 shopItemId
  lastGreetingAt            DateTime?
  unlockedItems             String    @default("[]")
  createdAt                 DateTime  @default(now())
  updatedAt                 DateTime  @updatedAt
}

model ShopItem {
  id               String    @id @default(cuid())
  name             String
  itemType         String    @default("cosmetic") // penalty_reduction | grace_period | affinity_boost | cosmetic
  effectValue      Int       @default(0)         // 減輕處罰: 90=扣90%, 寬限期: 天數, 好感度: +N
  pointsCost       Int
  affinityRequired Int       @default(0)
  imageUrl         String?
  sortOrder        Int       @default(0)
  createdAt        DateTime  @default(now())
  userItems        UserItem[]
}

model UserItem {
  id         String    @id @default(cuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  shopItemId String
  shopItem   ShopItem  @relation(fields: [shopItemId], references: [id], onDelete: Cascade)
  createdAt  DateTime  @default(now())

  @@unique([userId, shopItemId])
}
